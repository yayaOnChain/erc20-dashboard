{
  "name": "erc20-dashboard",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "compile": "npx hardhat compile",
    "test": "npm run test:contract && npm run test:frontend",
    "test:contract": "npx hardhat test src/test/token.test.ts",
    "test:frontend": "vitest run",
    "test:frontend:watch": "vitest",
    "test:ui": "vitest --ui",
    "deploy:local": "npx hardhat run src/scripts/deploy.ts --network localhost",
    "deploy:sepolia": "npx hardhat run src/scripts/deploy.ts --network sepolia",
    "node": "npx hardhat node"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "ethers": "^6.15.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.2",
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "@openzeppelin/contracts": "^5.4.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.22",
    "chai": "^4.5.0",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "hardhat": "^2.22.0",
    "jsdom": "^29.0.1",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.1.1"
  }
}
